# Café Loyalty — build-time configuration (Vite reads VITE_* at build).
#
# These are PROTOTYPE secrets. There is no server: anything here is baked into
# the static bundle and is publicly readable. Use throwaway, rate-limited values
# and rotate them after demos. For deployment, set the same names as repository
# secrets (Settings → Secrets and variables → Actions) so the Pages workflow
# injects them — do NOT commit a filled-in .env. For local dev, copy this to
# `.env.local` (gitignored) and fill it in.

# EmailJS (client-side send) — powers self-service recovery + reward emails.
# Without all three, email silently no-ops (NoopMailer).
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Metered TURN relay — required for cross-network PeerJS registration (the demo
# typically has the customer on cellular and staff on wifi). Without these, only
# STUN is used and NAT traversal across networks usually fails.
VITE_TURN_HOST=global.relay.metered.ca
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# Production swaps (leave unset for the prototype):
#   VITE_TRANSPORT=server   # use the server-mediated transport instead of PeerJS
#   VITE_DATASTORE=api      # use the HTTP DataStore instead of IndexedDB
#   VITE_API_BASE=/api
